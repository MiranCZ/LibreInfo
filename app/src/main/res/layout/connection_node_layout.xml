<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<!--    this inner layout is like useless lol-->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            >

            <FrameLayout
                android:id="@+id/vehicle_line_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <FrameLayout
                android:id="@+id/transfer_gradient"
                android:layout_width="6dp"
                android:layout_height="0dp"
                app:layout_constraintStart_toStartOf="@id/vehicle_line_icon"
                app:layout_constraintEnd_toEndOf="@id/vehicle_line_icon"
                app:layout_constraintTop_toBottomOf="@id/vehicle_line_icon"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="@color/secondaryColor" />

            <TextView
                android:id="@+id/vehicle_heading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/secondaryColor"
                android:fontFamily="@font/roboto_black"
                android:textSize="16sp"
                app:layout_constraintStart_toEndOf="@id/vehicle_line_icon"
                app:layout_constraintTop_toTopOf="@id/vehicle_line_icon"
                app:layout_constraintBottom_toBottomOf="@id/vehicle_line_icon" />

            <LinearLayout
                android:id="@+id/from_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintStart_toStartOf="@id/vehicle_heading"
                app:layout_constraintTop_toBottomOf="@id/vehicle_line_icon"
                android:layout_marginBottom="4dp"
                >

                <TextView
                    android:id="@+id/time_from"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:textColor="@color/secondaryColor"
                    android:fontFamily="@font/roboto_bold"
                    android:gravity="center_vertical"
                    android:textSize="14.5sp" />

                <TextView
                    android:id="@+id/stop_from"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/secondaryColor"
                    android:fontFamily="@font/roboto_regular"
                    android:singleLine="true"
                    android:textSize="14.5sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="@id/vehicle_heading"
                app:layout_constraintTop_toBottomOf="@id/from_info"
                >

                <TextView
                    android:id="@+id/time_to"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:textColor="@color/secondaryColor"
                    android:fontFamily="@font/roboto_bold"
                    android:gravity="center_vertical"
                    android:textSize="14.5sp" />

                <TextView
                    android:id="@+id/stop_to"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/secondaryColor"
                    android:fontFamily="@font/roboto_regular"
                    android:singleLine="true"
                    android:textSize="14.5sp" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.constraintlayout.widget.ConstraintLayout>
